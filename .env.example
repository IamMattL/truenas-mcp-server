# TrueNAS MCP Server Configuration
# Copy this file to .env and update with your settings

# TrueNAS Connection Settings
TRUENAS_HOST=nas.pvnkn3t.lan
TRUENAS_PORT=443
TRUENAS_PROTOCOL=wss

# TrueNAS API Authentication
# Get your API key from TrueNAS: System Settings -> Advanced -> API Keys
TRUENAS_API_KEY=your-api-key-here

# SSL/TLS Settings
# Set to "false" for self-signed certificates (development)
# Set to "true" for production with valid certificates
TRUENAS_SSL_VERIFY=false

# Development Settings
DEBUG_MODE=false
MOCK_TRUENAS=false

# Dynamic tool discovery (Cloudflare pattern)
# When true, the server exposes only two meta-tools (search_tools and
# execute_tool) instead of registering all 33 tools upfront. This cuts the
# baseline context footprint by ~94% and keeps it flat as tools are added.
MCP_DISCOVERY_MODE=false

# Optional: Logging Configuration
LOG_LEVEL=INFO

# Transport mode: "stdio" (default, local clients) or "http" (remote
# clients behind a Cloudflare Server Portal / Mesh-private endpoint).
# In http mode the server expects auth + per-tool policy to be handled
# upstream — do not expose this port to the public internet.
MCP_TRANSPORT=stdio

# HTTP transport (only used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
# Comma-separated list of allowed Origin headers for DNS-rebinding
# protection. Defaults to "*" if unset; tighten this once the portal's
# hostname is known.
# MCP_ALLOWED_ORIGINS=https://your-portal.example