# TrueNAS MCP Server Configuration
# Copy this file to .env and update with your settings

# TrueNAS Connection Settings
TRUENAS_HOST=nas.pvnkn3t.lan
TRUENAS_PORT=443
TRUENAS_PROTOCOL=wss

# TrueNAS API Authentication
# Get your API key from TrueNAS: System Settings -> Advanced -> API Keys
TRUENAS_API_KEY=your-api-key-here

# SSL/TLS Settings
# Set to "false" for self-signed certificates (development)
# Set to "true" for production with valid certificates
TRUENAS_SSL_VERIFY=false

# Development Settings
DEBUG_MODE=false
MOCK_TRUENAS=false

# Optional: Logging Configuration
LOG_LEVEL=INFO

# =============================================================================
# Cloudflare AI Controls Configuration (Remote HTTP Transport)
# =============================================================================
# Set MCP_TRANSPORT=http to enable remote access via Cloudflare

# Transport mode: "stdio" (default, local) or "http" (remote, Cloudflare)
MCP_TRANSPORT=stdio

# HTTP Transport Settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080

# Cloudflare Access Authentication
# Get these from: Cloudflare One Dashboard -> Access -> Applications
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=your-application-audience-tag

# Rate Limiting (defense-in-depth; use Cloudflare AI Gateway for primary)
RATE_LIMIT_RPM=60

# Allowed Origins for CORS/DNS rebinding protection (comma-separated)
# MCP_ALLOWED_ORIGINS=https://your-portal.cloudflareaccess.com